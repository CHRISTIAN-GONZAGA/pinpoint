# =============================================================================
# PINPOINT Backend — environment variables
# =============================================================================
# Local:  copy to backend/.env
# Render: set these in the Render Dashboard for service "pinpoint-api"
# =============================================================================

# --- Core ---
FLASK_ENV=production
DEBUG_MODE=false
AUTO_SEED=true
APP_VERSION=2.0.0
API_PREFIX=/api
PORT=10000

# --- Security (Render auto-generates these via render.yaml) ---
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret-32-characters-minimum

# --- Database ---
# Local SQLite:
# DATABASE_URL=sqlite:///pinpoint.db
#
# Render PostgreSQL (auto-injected when linked to pinpoint-db):
# DATABASE_URL=postgres://pinpoint:xxxx@dpg-xxxx-a.singapore-postgres.render.com/pinpoint
# (config.py normalizes this to postgresql+psycopg2:// with sslmode=require)
DATABASE_URL=sqlite:///pinpoint.db

# --- CORS (mobile apps ignore CORS; restrict for web clients if needed) ---
CORS_ORIGINS=*

# --- Caching ---
CACHE_TTL_SECONDS=60

# --- AI / RAG (optional on Render — set OPENAI_API_KEY in dashboard) ---
AI_USE_CHROMA=false
AI_RETRIEVAL_TOP_K=5
VECTOR_DB_PATH=./chroma_data
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_KEY=
