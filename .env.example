# =============================================================================
# PINPOINT — Environment variables reference
# =============================================================================
#
# RENDER (backend web service: pinpoint-api)
#   Dashboard → pinpoint-api → Environment
#   Or deploy via render.yaml (Blueprint) — most vars are pre-filled there.
#
# FLUTTER (mobile app — NOT set on Render)
#   Copy the Flutter section to `.env.flutter.json` and build with:
#   flutter run --dart-define-from-file=.env.flutter.json
#
# =============================================================================


# =============================================================================
# RENDER — Web service `pinpoint-api` (backend/.env on Render)
# =============================================================================

# --- Core (required) ---
FLASK_ENV=production
DEBUG_MODE=false
AUTO_SEED=true
APP_VERSION=2.0.0
API_PREFIX=/api

# PORT is injected automatically by Render — do not set unless self-hosting elsewhere.
# PORT=10000

# --- Security (required in production) ---
# render.yaml auto-generates these; only set manually if not using Blueprint.
SECRET_KEY=
JWT_SECRET_KEY=

# --- Database (required on Render) ---
# Auto-linked from Render PostgreSQL `pinpoint-db` when using render.yaml.
# Format from Render: postgres://pinpoint:PASSWORD@dpg-xxxx-a.region-postgres.render.com/pinpoint
DATABASE_URL=

# --- CORS ---
CORS_ORIGINS=*

# --- API caching ---
CACHE_TTL_SECONDS=60

# --- AI / RAG (optional — add in Render Dashboard for smart cloud AI chat) ---
# Recommended FREE setup (OpenRouter):
#   1. Create account at https://openrouter.ai
#   2. Generate API key → paste as OPENROUTER_KEY below
#   3. Set:
#        OPENROUTER_KEY=sk-or-v1-...
#        OPENAI_BASE_URL=https://openrouter.ai/api/v1
#        AI_MODEL=google/gemma-2-9b-it:free
#   Other free models: meta-llama/llama-3.2-3b-instruct:free, qwen/qwen-2-5-7b-instruct:free
# Alternative: Groq (https://console.groq.com) with OPENAI_BASE_URL=https://api.groq.com/openai/v1
AI_USE_CHROMA=false
AI_RETRIEVAL_TOP_K=5
AI_MODEL=google/gemma-2-9b-it:free
EMBEDDING_MODEL=default
VECTOR_DB_PATH=./chroma_data
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_KEY=

# --- After first successful deploy, set on Render: ---
# AUTO_SEED=false


# =============================================================================
# RENDER — What render.yaml sets for you (reference only)
# =============================================================================
#
# | Variable           | Source                          |
# |--------------------|---------------------------------|
# | FLASK_ENV          | production                      |
# | DEBUG_MODE         | false                           |
# | AUTO_SEED          | true (set false after seeding)  |
# | APP_VERSION        | 2.0.0                           |
# | API_PREFIX         | /api                            |
# | CORS_ORIGINS       | *                               |
# | AI_USE_CHROMA      | false                           |
# | CACHE_TTL_SECONDS  | 60                              |
# | DATABASE_URL       | Linked from pinpoint-db         |
# | SECRET_KEY         | Auto-generated                  |
# | JWT_SECRET_KEY     | Auto-generated                  |
# | PORT               | Auto-injected by Render         |
#
# You must add manually in Render Dashboard (optional):
#   OPENAI_API_KEY=sk-...
#   OPENROUTER_KEY=sk-or-...
#
# Health check URL after deploy:
#   https://pinpoint-api.onrender.com/health
# API base URL for Flutter:
#   https://pinpoint-api.onrender.com/api


# =============================================================================
# FLUTTER — `.env.flutter.json` (build-time, not on Render)
# =============================================================================
#
# Copy to `.env.flutter.json`:
#
# {
#   "API_URL": "https://pinpoint-api.onrender.com/api",
#   "OFFLINE_FIRST_MODE": "false"
# }
#
# Replace `pinpoint-api` with your actual Render service hostname.

API_URL=https://pinpoint-api.onrender.com/api
OFFLINE_FIRST_MODE=false

# --- Local backend (Android emulator) ---
# API_URL=http://10.0.2.2:5000/api
# OFFLINE_FIRST_MODE=false

# --- Offline-first thesis mode (no Render backend) ---
# API_URL=http://10.0.2.2:5000/api
# OFFLINE_FIRST_MODE=true

# --- Physical device → PC on same Wi-Fi ---
# API_URL=http://192.168.1.100:5000/api
# OFFLINE_FIRST_MODE=false


# =============================================================================
# MAPS — No API keys on Render (called from Flutter app, not backend)
# =============================================================================
#
# Default basemap: Carto Voyager (light) / Dark Matter (dark) — free, POI labels.
# For Google Maps–style landmarks, add to `.env.flutter.json`:
#
#   "MAP_TILE_PROVIDER": "maptiler",
#   "MAP_TILE_API_KEY": "your_maptiler_key"
#
# Alternatives:
#   maptiler — streets-v2, 100k free tile requests/month (recommended)
#   mapbox   — streets-v12, 50k free monthly loads
#   carto    — free, no key (default)
#
# OpenStreetMap Nominatim search and OSRM routing use public endpoints.
# See README.md for production scaling notes.
